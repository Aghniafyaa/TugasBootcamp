{
  "name": "mocha-api-automation",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "jalanin": "mocha tests --recursive --timeout 5000 --reporter spec",
    "jalanin-report-html": "mocha tests --recursive --reporter mocha-simple-html-reporter --reporter-options output=report.html",
    "jalanin-report-json": "mocha tests --recursive --reporter json > test-result.json"
  },
  "dependencies":{
    "node-fetch": "^3.3.1",
    "ajv":"^8.12.0"
  },
  "devDependencies": {
    "mocha":"^10.2.0",
    "chai":"^4.3.8",
    "mocha-simple-html-reporter": "2.0.0"
  }
}
